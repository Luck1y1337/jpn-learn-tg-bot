# Токен бота от @BotFather
BOT_TOKEN=

# Telegram ID администратора — нужен для команды /broadcast (рассылка всем).
# Если 0, команда /broadcast недоступна. Свой ID можно узнать у @userinfobot.
ADMIN_ID=0

# Путь к файлу базы данных SQLite.
# На Railway с volume используйте /data/bot.db
DB_PATH=bot.db

# Часовой пояс для стрика и времени ежедневной рассылки.
# Примеры: UTC, Europe/Moscow, Asia/Tashkent
TIMEZONE=UTC

# ID стикера-благодарности после доната (необязательно)
THANK_YOU_STICKER_ID=
